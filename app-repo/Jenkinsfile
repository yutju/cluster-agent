pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    app: jenkins-agent
spec:
  containers:
  - name: kubectl
    image: alpine:latest
    command: ["sleep"]
    args: ["infinity"]
    securityContext:
      runAsUser: 0
    envFrom:
    - configMapRef:
        name: jenkins-infra-config
  - name: docker
    image: docker:dind
    securityContext:
      privileged: true
    env:
    - name: DOCKER_TLS_CERTDIR
      value: ""
"""
        }
    }

    environment {
        GITLAB_API_TOKEN = credentials('gitlab-token-id')
        GITLAB_URL       = "${env.GITLAB_URL}"
        GITLAB_PROJECT_ID = "root%2Fapp-repo"
        JENKINS_WEBHOOK_URL = "http://${env.JENKINS_IP}:${env.JENKINS_PORT}/project/jenkins-test-pipeline"

        // 🌟 ECR 및 이미지 설정
        AWS_ACCOUNT_ID = "407002402096"
        AWS_REGION     = "ap-northeast-2"
        ECR_REGISTRY   = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        ECR_REPO_NAME  = "dev-apps/hello-k3s"
        IMAGE_TAG      = "${BUILD_NUMBER}"
        ECR_IMAGE_URI  = "${ECR_REGISTRY}/${ECR_REPO_NAME}:${IMAGE_TAG}"

        // 🌟 파드 내부 네트워크(TCP)로 안전하게 통신
        DOCKER_HOST    = "tcp://localhost:2375"
    }

    stages {
        stage('0. 기본 에이전트 도구 주입') {
            steps {
                container('kubectl') {
                    // 🌟 aws-cli 설치 후, kubectl 프로그램까지 다운로드해서 설치합니다!
                    sh """
                    apk add --no-cache curl openssl docker-cli bash git aws-cli > /dev/null
                    curl -sLO "https://dl.k8s.io/release/v1.29.0/bin/linux/amd64/kubectl"
                    chmod +x kubectl
                    mv kubectl /usr/local/bin/
                    """
                }
            }
        }

        stage('1. 코드 체크아웃') {
            steps { checkout scm }
        }

        stage('2. GitLab 웹훅 자동 등록') {
            steps {
                container('kubectl') {
                    script {
                        def gitlabApiBase = "${env.GITLAB_URL}/api/v4"
                        sh """
                        EXISTING_HOOK=\$(curl --header "PRIVATE-TOKEN: ${env.GITLAB_API_TOKEN}" --silent "${gitlabApiBase}/projects/${env.GITLAB_PROJECT_ID}/hooks" | grep "${env.JENKINS_WEBHOOK_URL}" || true)
                        if [ -z "\$EXISTING_HOOK" ]; then
                            curl --header "PRIVATE-TOKEN: ${env.GITLAB_API_TOKEN}" --request POST "${gitlabApiBase}/projects/${env.GITLAB_PROJECT_ID}/hooks?url=${env.JENKINS_WEBHOOK_URL}&push_events=true&token=jenkins-test-secret&enable_ssl_verification=false"
                        fi
                        """
                    }
                }
            }
        }

        stage('3. Docker Image Build & ECR Push') {
            steps {
                container('kubectl') {
                    script {
                        // 🌟 도커 데몬 대기
                        sh """
                        until docker info >/dev/null 2>&1; do
                            echo "Waiting for Docker daemon to start..."
                            sleep 2
                        done
                        """

                        // 1. 이미지 빌드
                        sh "docker build -t ${ECR_IMAGE_URI} ."

                        // 2. AWS 인증 및 푸시
                        withCredentials([usernamePassword(credentialsId: 'aws-ecr-cred', passwordVariable: 'AWS_SECRET', usernameVariable: 'AWS_ACCESS')]) {
                            sh """
                                aws configure set aws_access_key_id \${AWS_ACCESS}
                                aws configure set aws_secret_access_key \${AWS_SECRET}
                                aws configure set default.region ${AWS_REGION}

                                aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}
                                docker push ${ECR_IMAGE_URI}
                            """
                        }
                    }
                }
            }
        }

        stage('4. ECR Secret 자동 갱신 (12시간 제한 해제)') {
            steps {
                container('kubectl') {
                    script {
                        sh """
                        NEW_PASSWORD=\$(aws ecr get-login-password --region ${AWS_REGION})

                        # 기존 시크릿 삭제 및 재생성 (Namespace: dev-apps)
                        kubectl delete secret ecr-secret -n dev-apps --ignore-not-found
                        kubectl create secret docker-registry ecr-secret \
                          --docker-server=${ECR_REGISTRY} \
                          --docker-username=AWS \
                          --docker-password=\$NEW_PASSWORD \
                          -n dev-apps
                        echo "✅ ECR Secret이 최신 토큰으로 갱신되었습니다."
                        """
                    }
                }
            }
        }

        stage('5. GitOps 레포 자동 수정 및 푸시') {
            steps {
                container('kubectl') {
                    script {
                        withCredentials([usernamePassword(credentialsId: 'gitlab-checkout-cred', passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]) {
                            sh """
                                git config --global user.email "jenkins@jenkins.com"
                                git config --global user.name "Jenkins-CI"
                                git config --global http.sslVerify false

                                rm -rf gitops-repo-tmp
                                git clone -b main http://\${GIT_USERNAME}:\${GIT_PASSWORD}@192.168.72.131/root/gitops-repo.git gitops-repo-tmp

                                # 🌟 경로 수정 완료 (중복된 gitops-repo 폴더명 제거)
                                sed -i "s|image: .*|image: ${ECR_IMAGE_URI}|g" gitops-repo-tmp/kubernetes/apps/app/test-deployment.yaml

                                # 🌟 이동 경로 수정 완료
                                cd gitops-repo-tmp
                                git add kubernetes/apps/app/test-deployment.yaml
                                git commit -m "image: ECR 이미지 업데이트 (Build #${IMAGE_TAG})"
                                git push origin main
                            """
                        }
                    }
                }
            }
        }
    }
}
